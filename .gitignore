# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright MCP scratch output (snapshots, console logs) — regenerated per run.
.playwright-mcp/

# Claude Code local settings. Already covered by a global gitignore on this
# machine, but repeated here so the rule travels with the repo.
.claude/

# AI assistant context files — kept locally, deliberately not version-controlled.
# REBUILD.md was never tracked and is also excluded via .git/info/exclude.
AGENTS.md
CLAUDE.md
MEMORY.md
REBUILD.md
